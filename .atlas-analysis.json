  "keyFeatures": [
    "Inventory management with real-time stock tracking",
    "Sales processing with multiple payment methods",
    "Analytics and reporting with custom date ranges",
    "Automated alerts for low stock and important events",
    "User authentication with role-based access control",
    "Supplier and brand management",
    "Customer tracking and history",
    "Multi-user support for administrators and employees"
  ],
  "publicApiSurface": [
    "POST /auth/login - User authentication",
    "POST /auth/register - User registration",
    "POST /auth/logout - User logout",
    "GET /auth/verify - Verify authentication token",
    "POST /auth/recover - Password recovery",
    "GET /inventory - Get products with filters",
    "POST /inventory - Create new product",
    "PUT /inventory/:id - Update product",
    "DELETE /inventory/:id - Delete product",
    "GET /sales - Get sales with filters",
    "POST /sales - Create new sale",
    "GET /sales/:id - Get specific sale",
    "PUT /sales/:id/status - Update sale status",
    "GET /sales/reports/summary - Get sales summary report",
    "GET /sales/products/search - Search products for sale",
    "GET /sales/users/vendedores - Get list of sellers",
    "GET /analysis/sales - Get sales analytics",
    "GET /analysis/sales/summary - Get executive summary",
    "GET /analysis/sales/custom - Get custom period analytics",
    "GET /alerts - Get alerts",
    "POST /alerts - Create alert",
    "PUT /alerts/:id - Update alert"
  ]
